# ── LLM Provider ─────────────────────────────────────────────────────────────
# PAID=true  → every LLM task uses OpenAI gpt-5.4-mini (no fallback chain).
# PAID=false → free workflow (the LLM_* / *_FALLBACK_* settings below).
PAID=false

LLM_PROVIDER=groq              # groq | openai | anthropic | gemini | ollama
LLM_MODEL=                     # Heavy model for framework + PRD. Blank = provider default
GROQ_API_KEY=your_key_here     # Free at console.groq.com

# Fallback for framework + PRD: if the primary provider is exhausted/rate-limited
# (or returns empty), these models are tried automatically. Leave blank to disable.
LLM_FALLBACK_PROVIDER=         # e.g. groq
LLM_FALLBACK_MODEL=

# Transcript cleaning: local (regex, no LLM calls) | llm (light model, regex fallback)
CLEANING_MODE=local

# Ingestion model — light/cheap model used for transcript cleaning when
# CLEANING_MODE=llm. Defaults to LLM_PROVIDER's light model. High rate limit best.
INGESTION_PROVIDER=
INGESTION_MODEL=

# Vision model — light multimodal model for image description.
# Defaults to LLM_PROVIDER's vision model if left blank.
VISION_PROVIDER=
VISION_MODEL=

# Paid-mode (PAID=true) — OpenAI key + optional project scope. Model is fixed
# to gpt-5.4-mini and applies to every LLM task.
OPENAI_API_KEY=
OPENAI_PROJECT=                # optional; e.g. ProductAIGenius or proj_XXXXX

ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Change to postgresql://user:pass@host/dbname for PostgreSQL. Zero code change.
DATABASE_URL=sqlite:///./aipm.db

# ── File Storage ──────────────────────────────────────────────────────────────
# local → ./storage on disk (dev).  db → files stored in the SQL database
# (recommended for hosting: persists with the DB, no object storage needed).
STORAGE_BACKEND=local          # local | db | s3
STORAGE_LOCAL_PATH=./storage

# S3 — only needed when STORAGE_BACKEND=s3 (stub, not implemented in v1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=

# ── Auth / Accounts ─────────────────────────────────────────────────────────
# AUTH_ENABLED=false → app is open (local dev).
# AUTH_ENABLED=true  → username/password login required (hosted deploy).
AUTH_ENABLED=false
# ALLOW_REGISTRATION=true → visitors can self-register a "Create account" tab.
# Set to false to lock signups to seeded/admin-created accounts only.
ALLOW_REGISTRATION=true
# Secret used to encrypt per-user LLM API keys at rest. Any long random string.
# Generate one with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=
# Public URL of the deployed app — used to build password-reset links in emails.
APP_BASE_URL=
# Optional: auto-create this admin account on first startup (idempotent).
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ── Email (password reset) — Resend ──────────────────────────────────────────
# Free at resend.com. Without a key, reset links are shown on screen instead.
RESEND_API_KEY=
EMAIL_FROM=PM Pilot <onboarding@resend.dev>

# ── Pipeline Behaviour ────────────────────────────────────────────────────────
# HITL_ENABLED=false → pipeline runs fully automatically (v1 default)
# HITL_ENABLED=true  → pipeline pauses after Node 2 for human review (v2)
HITL_ENABLED=false

# ── Jira (v2 — push not implemented in v1, only JSON export) ─────────────────
JIRA_ENABLED=false
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROD
