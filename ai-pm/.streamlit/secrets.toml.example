# Streamlit Community Cloud → app → Settings → Secrets.
# Copy this to .streamlit/secrets.toml (gitignored) and fill in real values, OR
# paste the filled-in version into Streamlit Cloud's Secrets box.
# Streamlit exposes each root-level key here as an environment variable, which
# config.py reads. NEVER put real secrets in this .example file — it is committed.

# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Use Neon's "psycopg2 / SQLAlchemy" connection string. Must start with
# postgresql:// (not postgres://). Keep ?sslmode=require.
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── File storage: keep files in the database ──────────────────────────────
STORAGE_BACKEND = "db"

# ── Auth ───────────────────────────────────────────────────────────────────
AUTH_ENABLED = "true"
# Long random string. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_SECRET_KEY = "REPLACE_WITH_LONG_RANDOM_STRING"
# Your live app URL (used in password-reset emails). No trailing slash.
APP_BASE_URL = "https://YOUR-APP.streamlit.app"

# Seed your first admin account on first boot (idempotent).
SEED_ADMIN_USERNAME = "admin"
SEED_ADMIN_EMAIL = "you@example.com"
SEED_ADMIN_PASSWORD = "CHANGE_ME_after_first_login"

# ── Email for password reset (Resend) ─────────────────────────────────────
# Optional. Without it, reset links are shown on screen instead of emailed.
RESEND_API_KEY = ""
EMAIL_FROM = "PM Pilot <onboarding@resend.dev>"

# ── LLM default (optional shared fallback) ────────────────────────────────
# Each user can set their own keys/models in the in-app Settings page. Anything
# they leave blank falls back to these. A free Groq key here means the app works
# out of the box before anyone configures their own.
LLM_PROVIDER = "groq"
GROQ_API_KEY = ""
CLEANING_MODE = "local"
